# ════════════════════════════════════════════════════════
# এই ফাইলটা copy করে ".env" নামে save করুন, তারপর value বসান
#   Windows:  copy .env.example .env
#   Hosting:  এই value গুলো Railway/Render dashboard এ বসান
# ════════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────
# নতুন SECRET_KEY বানাতে:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=এখানে-নতুন-secret-key-বসান

# Local এ True, Production এ False (বা লাইনটাই বাদ দিন)
DEBUG=True

# Production এ আপনার domain, কমা দিয়ে আলাদা:
# ALLOWED_HOSTS=api.tarbiyatulquran.org,tqa-backend.up.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ────────────────────────────────────────────
# Local এ এই লাইন বাদ দিলে SQLite ব্যবহার হবে (সহজ)
#
# ★ স্থায়ী (কখনো expire হয় না): Neon — neon.tech (FREE)
#   1. neon.tech → Sign up → Create project → "Connection string" কপি করুন
#   2. "Connection Details" → "Direct connection" → URL কপি
# DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# ⚠️ Render built-in PostgreSQL ৯০ দিন পর delete হয় — Neon ব্যবহার করুন

# ── CORS (Frontend এর ঠিকানা) ───────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Production এ (www সহ দুটোই দিন):
# CORS_ALLOWED_ORIGINS=https://tarbiyatulquran.org,https://www.tarbiyatulquran.org
# CSRF_TRUSTED_ORIGINS=https://api.tarbiyatulquran.org
# অথবা সব origin খুলতে (public form API-র জন্য নিরাপদ — rate limit আছে):
# CORS_ALLOW_ALL_ORIGINS=True

# ── Celery / Redis ──────────────────────────────────────
# Local এ এই লাইন বাদ দিলে localhost Redis ব্যবহার হবে
# Production এ Upstash/Railway Redis URL:
# REDIS_URL=redis://default:password@host:6379

# ── Cron Security (ফ্রি hosting এ Celery র বদলে) ────────
# নতুন secret বানাতে: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_SECRET=এখানে-লম্বা-random-secret-বসান

# Celery ব্যবহার করবেন? Render free plan এ False রাখুন
USE_CELERY=False

# ── Cloudinary (uploaded files স্থায়ী রাখার জন্য) ──────────────
# cloudinary.com → Dashboard থেকে "API Environment variable" কপি করুন
# format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
