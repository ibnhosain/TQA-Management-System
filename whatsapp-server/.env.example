# এই ফাইল copy করে ".env" নামে save করুন
# Hosting এ এই value গুলো Railway/Render dashboard এ বসান

PORT=3001

# Provider: meta অথবা twilio
WHATSAPP_PROVIDER=meta

# ── Meta (WhatsApp Cloud API) ──
META_ACCESS_TOKEN=আপনার-meta-access-token
META_PHONE_NUMBER_ID=আপনার-phone-number-id

# ── Twilio (বিকল্প) ──
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_WHATSAPP_FROM=+14155238886

# ঐচ্ছিক: শুধু আপনার সাইট থেকে request নিতে
# ALLOWED_ORIGIN=https://tarbiyatulquran.org
